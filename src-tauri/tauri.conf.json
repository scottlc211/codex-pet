{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Pet",
  "version": "0.1.0",
  "identifier": "com.codexpet.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Pet",
        "width": 260,
        "height": 260,
        "minWidth": 120,
        "minHeight": 120,
        "decorations": false,
        "transparent": true,
        "backgroundColor": [0, 0, 0, 0],
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "Codex Pet 设置",
        "width": 760,
        "height": 520,
        "minWidth": 680,
        "minHeight": 480,
        "center": true,
        "visible": false,
        "decorations": false,
        "transparent": false,
        "backgroundColor": [248, 251, 250, 255],
        "alwaysOnTop": false,
        "resizable": true,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.codex/pets/**",
          "$HOME/.codex-pet/pets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
